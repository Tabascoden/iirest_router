NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=https://router.iirest.ru

POSTGRES_DB=iirest_router
POSTGRES_USER=iirest
POSTGRES_PASSWORD=change_me_strong_password

DATABASE_URL=postgresql://iirest:change_me_strong_password@postgres:5432/iirest_router
REDIS_URL=redis://redis:6379

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BOT_KEY=main

MAX_ENABLED=false
MAX_MOCK_ENABLED=false
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
MAX_WEBHOOK_BOT_KEY=main
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_SEND_TIMEOUT_MS=10000
MAX_SEND_FORMAT=

RELAY_WS_PATH=/relay/stream
RELAY_ACK_TIMEOUT_SECONDS=10
RELAY_MAX_ATTEMPTS=3
RELAY_QUEUE_DRAIN_INTERVAL_SECONDS=5
RELAY_PING_INTERVAL_SECONDS=30
RELAY_PONG_TIMEOUT_SECONDS=10

MAX_ACTIVE_JOBS_PER_USER=1
MAX_ACTIVE_JOBS_PER_ASSISTANT=5
MAX_ACTIVE_JOBS_PER_RELAY_ACCOUNT=20
JOB_TIMEOUT_SECONDS=180
JOB_TIMEOUT_SCAN_INTERVAL_SECONDS=30
MAX_TEXT_LENGTH=4000
OUTBOUND_MAX_CHARS=3500
TELEGRAM_SEND_TIMEOUT_MS=10000
SUPPORT_PLATFORM=
SUPPORT_CHAT_ID=
WEBHOOK_RATE_LIMIT_PER_MINUTE=120

DAILY_CONTEXT_ROTATION_ENABLED=true
DAILY_CONTEXT_ROTATION_TIME=04:00
DAILY_CONTEXT_ROTATION_TIMEZONE=Europe/Moscow

IDLE_CONTEXT_RESET_ENABLED=true
IDLE_CONTEXT_RESET_MINUTES=360
IDLE_CONTEXT_SCAN_INTERVAL_SECONDS=60

QUEUE_WHEN_RELAY_OFFLINE=false
DEV_ENDPOINTS_ENABLED=false
STATUS_ENDPOINT_ENABLED=true
LOG_PII=false
LOG_LEVEL=info
