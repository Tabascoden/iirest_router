{
  "name": "iirest-router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "routerctl": "tsx src/cli/routerctl.ts",
    "mock:relay": "tsx tests/mocks/relay-client.mock.ts",
    "test": "vitest run",
    "smoke": "tsx scripts/smoke.ts",
    "telegram:set-commands": "tsx scripts/telegram-set-commands.ts",
    "max:subscribe": "tsx scripts/max-subscribe.ts",
    "max:subscriptions": "tsx scripts/max-subscriptions.ts",
    "max:unsubscribe": "tsx scripts/max-unsubscribe.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.1",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "tsx": "^4.20.6",
    "ulid": "^3.0.1",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
